{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["@types/bun", "node"]
  },
  "include": ["src/**/*.ts", "test/**/*.ts", "drizzle.config.ts"]
}
