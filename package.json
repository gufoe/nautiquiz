{
  "name": "nautiquiz",
  "private": true,
  "workspaces": ["api", "ui", "packages/*"],
  "scripts": {
    "catalog:generate": "bun ui/scripts/generate-quiz-catalog.ts",
    "dev:ui": "bun run --cwd ui dev",
    "dev:api": "bun run --cwd api dev",
    "build:ui": "bun run --cwd ui build",
    "build:api": "bun run --cwd api build",
    "db:generate": "bun run --cwd api db:generate",
    "db:migrate": "bun run --cwd api db:migrate",
    "dev:test": "docker compose -f docker-compose.dev.yml run --rm api sh -c \"bun install && bun run test\""
  },
  "packageManager": "bun@1.3.10",
  "overrides": {
    "vite": "5.4.3"
  }
}
